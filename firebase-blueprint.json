{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "MarketingPlan": {
      "title": "Marketing Plan",
      "description": "Generated marketing strategy",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productName": { "type": "string" },
        "targetAudience": { "type": "string" },
        "price": { "type": "string" },
        "goal": { "type": "string", "enum": ["Sales", "Leads"] },
        "marketResearch": { "type": "string" },
        "funnelPlan": { "type": "string" },
        "adCopies": { "type": "string" },
        "headlines": { "type": "string" },
        "offerStrategy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productName", "targetAudience", "price", "goal", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile"
    },
    "/plans/{planId}": {
      "schema": "MarketingPlan",
      "description": "Marketing plans generated by users"
    }
  }
}
